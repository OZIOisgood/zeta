# Database Configuration
DB_URL=postgres://zeta:zeta@localhost:5432/zeta?sslmode=disable

# WorkOS Configuration
WORKOS_API_KEY=sk_*
WORKOS_CLIENT_ID=client_*
WORKOS_REDIRECT_URI=http://localhost:8080/auth/callback
MOBILE_REDIRECT_URI=zeta://auth/callback
DEFAULT_ORG_ID=org_*****************

# Mux Configuration
MUX_TOKEN_ID=00000000-0000-0000-0000-000000000000
MUX_TOKEN_SECRET=***************************************************************************

# Resend Configuration
RESEND_API_KEY=re_*
RESEND_FROM_EMAIL=notifications@dev.zeta.m4xon.com
# Optional absolute logo URL for rendered emails. Defaults to FRONTEND_URL + /app-full-icon.png, then the hosted dev icon.
EMAIL_LOGO_URL=https://dev.zeta.m4xon.com/app-full-icon.png

# OpenRouter Configuration (for LLM text enhancement)
OPENROUTER_API_KEY=sk-or-*

# Agora Configuration (for live coaching video calls)
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Agora Cloud Recording (optional; disabled by default)
# Create REST credentials in Agora Console > Developer Toolkit > RESTful API.
AGORA_CLOUD_RECORDING_ENABLED=false
AGORA_REST_CUSTOMER_ID=your_agora_customer_id
AGORA_REST_CUSTOMER_SECRET=your_agora_customer_secret
AGORA_CLOUD_RECORDING_BASE_URL=https://api.sd-rtn.com
AGORA_RECORDING_MODE=mix
# Deployed dev/prod storage is provisioned by Terraform as a GCS bucket plus HMAC credentials.
# For Google Cloud Storage, Agora uses vendor=6 and region=0.
AGORA_RECORDING_STORAGE_VENDOR=6
AGORA_RECORDING_STORAGE_REGION=0
AGORA_RECORDING_STORAGE_BUCKET=your_gcs_recording_bucket
AGORA_RECORDING_STORAGE_ACCESS_KEY=your_gcs_hmac_access_key
AGORA_RECORDING_STORAGE_SECRET_KEY=your_gcs_hmac_secret_key
AGORA_RECORDING_FILE_PREFIX=liveCoachingRecordings
# Optional for local signed URL generation. Cloud Run auto-detects its runtime service account.
GCS_SIGNING_SERVICE_ACCOUNT=
AGORA_RECORDING_MAX_IDLE_TIME=30
AGORA_RECORDING_TRANSCODING_WIDTH=640
AGORA_RECORDING_TRANSCODING_HEIGHT=360
AGORA_RECORDING_TRANSCODING_BITRATE=1500
AGORA_RECORDING_TRANSCODING_FPS=30

# Internal Scheduler Secret (for Cloud Scheduler → /internal/coaching/reminders)
SCHEDULER_SECRET=your_scheduler_secret

# Coaching Time Constraints (Go duration syntax: 0s, 5m, 2h)
# Set to 0s for instant testing — defaults are production-safe.
MIN_BOOKING_NOTICE=2h
CANCELLATION_NOTICE=1h
CONNECT_WINDOW=15m

# Development Configuration
# WARNING: Never set DEV_AUTH_ENABLED=true in production!
# Enables POST /auth/token for Bruno API tests (password-based token issuance).
# Also switches session cookies to Secure=false + SameSite=Lax so they work
# over plain HTTP (http://localhost:4200) during local development.
DEV_AUTH_ENABLED=false

# Logging Configuration
LOG_LEVEL=info

# I18n Configuration
DEFAULT_LANGUAGE=en
