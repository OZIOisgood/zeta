# Hoist the Babel toolchain to the top-level node_modules so bare plugin/preset
# names referenced *inside* babel-preset-expo (e.g. @babel/plugin-transform-react-jsx)
# resolve under pnpm's strict layout. Required by the Storybook
# (react-native-web-vite) Babel pass, which resolves names against a virtual base.
public-hoist-pattern[]=*babel-plugin*
public-hoist-pattern[]=*babel-preset*
public-hoist-pattern[]=@babel/*
