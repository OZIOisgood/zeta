{
  "expo": {
    "name": "Zeta",
    "slug": "zeta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "zeta",
    "userInterfaceStyle": "automatic",
    "owner": "henry2k",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.m4xon.zeta",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Zeta uses the microphone for live coaching calls."
      }
    },
    "android": {
      "package": "com.m4xon.zeta",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Zeta to access your video library to upload videos for review.",
          "cameraPermission": "Allow Zeta to access your camera."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Zeta to scan QR codes to join groups."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Zeta to add your booked coaching sessions to your calendar."
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "66b21f55-ac40-45c0-a58d-ebe59034840e"
      }
    }
  }
}
