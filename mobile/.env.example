# Copy to .env for local development. EXPO_PUBLIC_* values are public client config.
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_WORKOS_CLIENT_ID=client_xxx
# Web app base URL used to build group invite links (e.g. https://app.zeta.example.com).
# The QR code and share link will embed <EXPO_PUBLIC_WEB_BASE_URL>/groups?invite=<code>.
EXPO_PUBLIC_WEB_BASE_URL=http://localhost:4200
