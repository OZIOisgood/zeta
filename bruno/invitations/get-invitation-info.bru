meta {
  name: Get Invitation Info
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/groups/invitations/{{inviteCode}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminBearerToken}}
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.code).to.equal(bru.getVar("inviteCode"));
  expect(res.body.group_name).to.be.a("string");
}
