meta {
  name: Get Asset
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/assets/{{assetId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.id).to.equal(bru.getVar("assetId"));
  expect(res.body.title).to.equal("Test Asset");
  expect(res.body.videos).to.be.an("array");
  expect(res.body.videos.length).to.equal(1);
}
