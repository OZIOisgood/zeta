meta {
  name: Update Review
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/assets/videos/{{videoId}}/reviews/{{reviewId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

body:json {
  {
    "content": "Updated review content from Bruno"
  }
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.id).to.equal(bru.getVar("reviewId"));
  expect(res.body.content).to.equal("Updated review content from Bruno");
  expect(res.body.created_at).to.be.a("string");
}
