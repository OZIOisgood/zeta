meta {
  name: Update Group
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/groups/{{newGroupId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminBearerToken}}
}

body:json {
  {
    "name": "Test Group Updated",
    "description": "Updated by Bruno tests"
  }
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.id).to.equal(bru.getVar("newGroupId"));
  expect(res.body.name).to.equal("Test Group Updated");
  expect(res.body.updated_at).to.be.a("string");
}
