meta {
  name: Get Token
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

body:json {
  {
    "email": "{{testEmail}}",
    "password": "{{testPassword}}"
  }
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.token).to.be.a("string");
  expect(res.body.token).to.have.length.above(10);

  bru.setVar("adminBearerToken", res.body.token);
}
