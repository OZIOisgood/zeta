meta {
  name: Me
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.id).to.be.a("string");
  expect(res.body.email).to.be.a("string");
  expect(res.body.role).to.be.a("string");
  expect(res.body.permissions).to.be.an("array");
}
