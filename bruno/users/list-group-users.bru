meta {
  name: List Group Users
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/groups/{{groupId}}/users
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminBearerToken}}
}

tests {
  expect(res.status).to.equal(200);
  expect(res.body.data).to.be.an("array");
  expect(res.body.data.length).to.be.above(0);
  expect(res.body.data[0].id).to.be.a("string");
  expect(res.body.data[0].email).to.be.a("string");
  expect(res.body.data[0].role).to.be.a("string");
}
